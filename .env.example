# Environment Variable Configuration
# ==================================
#
# DEPLOY_ENV (development | staging | production)
#   Controls fallback behavior and validation strictness.
#   Default: development (no validation, allows direct-runtime fallback)
#   staging/production: HERMES_API_BASE must be set; Web->Runtime fallback disabled
#
# AUTH_MODE (disabled | mock | oidc)
#   Controls authentication mode.
#   Default: disabled (no auth, identity from query params / headers)
#   mock: enables login page, session cookies, server-side identity injection.
#         Web ignores client-supplied org/viewer query params in this mode.
#         Runtime reads MR_RUNTIME_AUTH_MODE for server-side enforcement.
#         Set MR_RUNTIME_AUTH_MODE to "mock" (or any non-disabled value)
#         alongside Web's AUTH_MODE=mock to enable runtime-level RBAC.
#   oidc: enables OIDC SSO login via a standard OIDC provider.
#         Requires OIDC_ISSUER, OIDC_CLIENT_ID, OIDC_CLIENT_SECRET.
#         Identity claims are configurable via OIDC_*_CLAIM vars.
#
# Web -> Hermes resolution (order):
#   HERMES_API_BASE > NEXT_PUBLIC_HERMES_API_BASE > http://127.0.0.1:8000
#
# Hermes -> Runtime resolution (order):
#   <SKILL>_RUNTIME_BASE > RUNTIME_API_BASE > http://127.0.0.1:8100
#
# Required vars by environment:
#   development:  none (all have defaults)
#   staging:      HERMES_API_BASE, MR_VISIT_JP_RUNTIME_BASE
#   production:   HERMES_API_BASE, MR_VISIT_JP_RUNTIME_BASE
# ==================================

# Deployment environment
DEPLOY_ENV=development

# Auth mode (disabled | mock | oidc)
AUTH_MODE=disabled
SESSION_SECRET=dev-secret-not-for-production

# Smoke check mock-auth login (used only when AUTH_MODE=mock)
SMOKE_AUTH_USER_ID=learner_demo_001
SMOKE_AUTH_PASSWORD=Welcome123

# OIDC SSO (used when AUTH_MODE=oidc)
# OIDC_ISSUER=https://keycloak.example.com/realms/my-realm
# OIDC_CLIENT_ID=cosi-web
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/api/auth/oidc/callback
# OIDC_LEARNER_ID_CLAIM=preferred_username
# OIDC_ORG_ID_CLAIM=org_id
# OIDC_ROLE_CLAIM=roles

# Web
WEB_PORT=3000
HERMES_API_BASE=http://127.0.0.1:8000

# Hermes Orchestrator
HERMES_HOST=0.0.0.0
HERMES_PORT=8000
MR_VISIT_JP_RUNTIME_BASE=http://127.0.0.1:8100
GP_VISIT_JP_RUNTIME_BASE=http://127.0.0.1:8200

# MR Runtime
MR_RUNTIME_HOST=0.0.0.0
MR_RUNTIME_PORT=8100
MR_RUNTIME_AUTH_MODE=disabled
MR_RUNTIME_MODEL_MODE=mock
MR_RUNTIME_DEMO_SEED_MODE=manual
MR_RUNTIME_PROMPT_PROFILE=alpha_baseline_v1
MR_RUNTIME_EXPERIMENT_ID=
MR_RUNTIME_EXPERIMENT_FLAGS=
MR_RUNTIME_MODEL_API_BASE=
MR_RUNTIME_MODEL_API_KEY=
MR_RUNTIME_MODEL_NAME=deepseek-v4-pro
MR_RUNTIME_MODEL_TIMEOUT_SEC=15
MR_RUNTIME_MODEL_MAX_RETRIES=1
MR_RUNTIME_MODEL_RETRY_BACKOFF_SEC=0

# GP Runtime
GP_RUNTIME_HOST=0.0.0.0
GP_RUNTIME_PORT=8200

# Persistence
MR_RUNTIME_PERSISTENCE_MODE=file
MR_RUNTIME_SQLALCHEMY_URL=postgresql+psycopg://cosi:cosi@localhost:5439/cosi
POSTGRES_HOST=localhost
POSTGRES_PORT=5439
POSTGRES_DB=cosi
POSTGRES_USER=cosi
POSTGRES_PASSWORD=cosi
REDIS_HOST=localhost
REDIS_PORT=6379

# Model provider placeholders
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
