{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MrScenario",
  "type": "object",
  "required": [
    "id",
    "title",
    "difficulty",
    "focus_subskills",
    "doctor_persona_id",
    "constraints",
    "success_criteria",
    "failure_patterns",
    "playbook"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "focus_subskills": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/subskillId" }
    },
    "doctor_persona_id": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "object",
      "required": ["max_turns"],
      "properties": {
        "max_turns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        }
      },
      "additionalProperties": false
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "playbook": {
      "type": "object",
      "required": [
        "learning_objective",
        "target_subskills",
        "expected_flow",
        "key_discovery_questions",
        "acceptable_evidence_moves",
        "common_failure_patterns",
        "recovery_moves",
        "completion_signals",
        "positive_example_moves",
        "negative_example_moves"
      ],
      "properties": {
        "learning_objective": { "type": "string", "minLength": 1 },
        "target_subskills": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/subskillId" }
        },
        "expected_flow": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "key_discovery_questions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptable_evidence_moves": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "common_failure_patterns": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "recovery_moves": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "completion_signals": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "positive_example_moves": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "negative_example_moves": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "subskillId": {
      "type": "string",
      "enum": [
        "preparation",
        "opening",
        "profiling",
        "scientific_delivery",
        "need_discovery",
        "objection_handling",
        "closing_followup"
      ]
    }
  },
  "additionalProperties": false
}
