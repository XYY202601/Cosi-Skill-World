{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeHumanReviewFeedbackImportResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary"],
  "properties": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "imported_count", "skipped_duplicate_count", "total_count"],
      "properties": {
        "schema_version": { "type": "integer", "minimum": 1 },
        "imported_count": { "type": "integer", "minimum": 0 },
        "skipped_duplicate_count": { "type": "integer", "minimum": 0 },
        "total_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
