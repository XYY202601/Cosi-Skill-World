{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeHumanReviewFeedbackExportResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle"],
  "properties": {
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "domain_id", "exported_at", "record_count", "records"],
      "properties": {
        "schema_version": { "type": "integer", "minimum": 1 },
        "domain_id": { "type": "string", "minLength": 1 },
        "exported_at": { "type": "string", "minLength": 1 },
        "record_count": { "type": "integer", "minimum": 0 },
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/humanReviewRecord"
          }
        }
      }
    }
  },
  "$defs": {
    "humanReviewRecord": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "domain_id", "record_id", "version", "session_id", "verdict", "created_at"],
      "properties": {
        "schema_version": { "type": "integer", "minimum": 1 },
        "domain_id": { "type": "string", "minLength": 1 },
        "record_id": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "verdict": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "minLength": 1 }
      }
    }
  }
}
