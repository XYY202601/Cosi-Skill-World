{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeFinishSessionResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "scenario_id",
    "learner_id",
    "status",
    "finish_reason",
    "review",
    "coach_continuity",
    "progress_snapshot",
    "experiment_context"
  ],
  "properties": {
    "session_id": { "type": "string", "minLength": 1 },
    "scenario_id": { "type": "string", "minLength": 1 },
    "learner_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "finish_reason": { "type": "string", "minLength": 1 },
    "review": {
      "$ref": "#/$defs/runtimeReview"
    },
    "coach_continuity": {
      "$ref": "#/$defs/coachContinuity"
    },
    "progress_snapshot": {
      "$ref": "#/$defs/progressSnapshot"
    },
    "experiment_context": {
      "$ref": "#/$defs/promptContextSummary"
    }
  },
  "$defs": {
    "reviewEvidence": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["summary"],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "turn_index": { "type": "integer", "minimum": 1 },
            "speaker": { "type": "string", "minLength": 1 },
            "excerpt": { "type": "string", "minLength": 1 },
            "tags": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "runtimeReview": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "rubric_version",
        "subskills",
        "overall_score",
        "overall_band",
        "strengths",
        "priority_subskills",
        "diagnosis",
        "coaching_feedback",
        "compliance_flags",
        "meta"
      ],
      "properties": {
        "rubric_version": { "type": "integer", "minimum": 1 },
        "subskills": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["score", "evidence"],
            "properties": {
              "score": { "type": "integer", "minimum": 0, "maximum": 5 },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/reviewEvidence" }
              }
            }
          }
        },
        "overall_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "overall_band": { "type": "string", "minLength": 1 },
        "strengths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "priority_subskills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "diagnosis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "selection_basis"],
          "properties": {
            "primary": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "kind",
                  "severity",
                  "summary",
                  "related_subskills",
                  "recommendation_focus"
                ],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "kind": { "type": "string", "minLength": 1 },
                  "severity": { "type": "string", "minLength": 1 },
                  "summary": { "type": "string", "minLength": 1 },
                  "related_subskills": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "recommendation_focus": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              }
            },
            "selection_basis": { "type": "string", "minLength": 1 }
          }
        },
        "coaching_feedback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "focus_subskills", "next_actions"],
          "properties": {
            "version": { "type": "integer", "minimum": 1 },
            "focus_subskills": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "next_actions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "compliance_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule_id", "tag", "severity", "summary", "related_diagnosis_types"],
            "properties": {
              "rule_id": { "type": "string", "minLength": 1 },
              "tag": { "type": "string", "minLength": 1 },
              "severity": { "type": "string", "minLength": 1 },
              "summary": { "type": "string", "minLength": 1 },
              "related_diagnosis_types": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "finish_reason",
            "turn_count",
            "evaluation_mode",
            "artifact_sources",
            "fallback_reasons",
            "model_meta",
            "prompting",
            "context"
          ],
          "properties": {
            "finish_reason": { "type": "string", "minLength": 1 },
            "turn_count": { "type": "integer", "minimum": 1 },
            "evaluation_mode": { "type": "string", "minLength": 1 },
            "artifact_sources": {
              "type": "object",
              "additionalProperties": false,
              "required": ["judge", "coach", "compliance"],
              "properties": {
                "judge": { "type": "string", "enum": ["rule", "model"] },
                "coach": { "type": "string", "enum": ["rule", "model"] },
                "compliance": { "type": "string", "enum": ["rule", "model"] }
              }
            },
            "artifact_modes": {
              "type": "object",
              "additionalProperties": false,
              "required": ["judge", "coach", "compliance"],
              "properties": {
                "judge": { "type": "string", "enum": ["rule", "model", "mock"] },
                "coach": { "type": "string", "enum": ["rule", "model", "mock"] },
                "compliance": { "type": "string", "enum": ["rule", "model", "mock"] }
              }
            },
            "fallback_reasons": {
              "type": "array",
              "items": { "type": "string" }
            },
            "model_meta": { "type": "object" },
            "prompting": {
              "$ref": "#/$defs/promptContextSummary"
            },
            "context": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "skill_id",
                "session_id",
                "learner_id",
                "prompt_profile",
                "trace_id",
                "locale"
              ],
              "properties": {
                "skill_id": { "type": "string", "minLength": 1 },
                "session_id": { "type": "string", "minLength": 1 },
                "learner_id": { "type": "string", "minLength": 1 },
                "prompt_profile": { "type": "string", "minLength": 1 },
                "trace_id": { "type": "string", "minLength": 1 },
                "locale": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "progressSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "learner_id",
        "total_sessions",
        "total_exp",
        "level",
        "updated_at",
        "latest_recommendations",
        "practice_path",
        "weakness_clusters",
        "subskills",
        "recent_history",
        "coach_memory",
        "curriculum",
        "skill_world",
        "performance_analytics"
      ],
      "properties": {
        "learner_id": { "type": "string", "minLength": 1 },
        "total_sessions": { "type": "integer", "minimum": 0 },
        "total_exp": { "type": "integer", "minimum": 0 },
        "level": { "type": "integer", "minimum": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "latest_recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["scenario_id", "title", "difficulty", "target_subskills", "reason", "recommendation_type"],
            "properties": {
              "scenario_id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "difficulty": { "type": "string", "minLength": 1 },
              "target_subskills": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "reason": { "type": "string", "minLength": 1 },
              "recommendation_type": { "type": "string" },
              "evidence_source": { "type": ["string", "null"] },
              "stop_condition": { "type": ["string", "null"] },
              "expected_difficulty": { "type": ["string", "null"] },
              "suggested_repetition_count": { "type": "integer", "minimum": 1 },
              "reason_category": { "type": "string", "minLength": 1 },
              "urgency": { "type": "string", "minLength": 1 },
              "urgency_reason": { "type": ["string", "null"] }
            }
          }
        },
        "practice_path": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_index", "scenario_id", "title", "difficulty", "target_subskills", "reason", "recommendation_type"],
            "properties": {
              "step_index": { "type": "integer", "minimum": 1 },
              "scenario_id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "difficulty": { "type": "string", "minLength": 1 },
              "target_subskills": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "reason": { "type": "string", "minLength": 1 },
              "recommendation_type": { "type": "string" },
              "evidence_source": { "type": ["string", "null"] },
              "stop_condition": { "type": ["string", "null"] },
              "expected_difficulty": { "type": ["string", "null"] },
              "suggested_repetition_count": { "type": "integer", "minimum": 1 },
              "reason_category": { "type": "string", "minLength": 1 },
              "urgency": { "type": "string", "minLength": 1 },
              "urgency_reason": { "type": ["string", "null"] }
            }
          }
        },
        "weakness_clusters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cluster_id", "subskills", "occurrences", "last_seen_at"],
            "properties": {
              "cluster_id": { "type": "string", "minLength": 1 },
              "subskills": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "occurrences": { "type": "integer", "minimum": 1 },
              "last_seen_at": { "type": "string", "minLength": 1 }
            }
          }
        },
        "subskills": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "exp",
              "level",
              "last_score",
              "trend",
              "rolling_average",
              "history_count"
            ],
            "properties": {
              "exp": { "type": "integer", "minimum": 0 },
              "level": { "type": "integer", "minimum": 1 },
              "last_score": { "type": "integer", "minimum": 0, "maximum": 5 },
              "trend": { "type": "string", "minLength": 1 },
              "rolling_average": { "type": "number", "minimum": 0, "maximum": 5 },
              "history_count": { "type": "integer", "minimum": 0 },
              "mastery_status": {
                "type": "string",
                "enum": ["needs_practice", "improving", "stable", "mastered"]
              },
              "review_status": {
                "type": "string",
                "enum": ["focus_now", "maintain", "soon", "due"]
              },
              "sessions_since_focus": { "type": ["integer", "null"], "minimum": 0 },
              "next_review_in_sessions": { "type": ["integer", "null"], "minimum": 0 },
              "status_reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "recent_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["session_id", "scenario_id", "overall_score", "timestamp"],
            "properties": {
              "session_id": { "type": "string", "minLength": 1 },
              "scenario_id": { "type": "string", "minLength": 1 },
              "overall_score": { "type": "integer", "minimum": 0, "maximum": 100 },
              "timestamp": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        },
        "coach_memory": {
          "type": "object",
          "required": ["version", "summary", "active_focus_subskills", "next_actions", "last_session", "updated_at"],
          "properties": {
            "version": { "type": "integer", "minimum": 1 },
            "summary": { "type": "string" },
            "active_focus_subskills": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "next_actions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "last_session": {
              "type": "object",
              "required": ["session_id", "scenario_id", "scenario_title", "persona_label", "overall_score", "timestamp"],
              "properties": {
                "session_id": { "type": "string" },
                "scenario_id": { "type": "string" },
                "scenario_title": { "type": "string" },
                "persona_label": { "type": "string" },
                "overall_score": { "type": ["integer", "null"] },
                "timestamp": { "type": "string" }
              },
              "additionalProperties": true
            },
            "teaching_plan": {
              "type": ["object", "null"],
              "required": [
                "version",
                "focus_subskills",
                "reason",
                "target_behavior",
                "success_criterion",
                "score_threshold"
              ],
              "properties": {
                "version": { "type": "integer", "minimum": 1 },
                "focus_subskills": { "type": "array", "items": { "type": "string" } },
                "reason": { "type": "string" },
                "target_behavior": { "type": "string" },
                "success_criterion": { "type": "string" },
                "score_threshold": { "type": "number" },
                "prior_evidence": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "summary": { "type": "string", "minLength": 1 },
                      "subskill_id": { "type": ["string", "null"] },
                      "turn_index": { "type": ["integer", "null"], "minimum": 1 },
                      "session_id": { "type": ["string", "null"] },
                      "scenario_id": { "type": ["string", "null"] },
                      "scenario_title": { "type": ["string", "null"] }
                    },
                    "required": ["summary"]
                  }
                }
              }
            },
            "last_teaching_plan_achievement": {
              "type": ["object", "null"],
              "properties": {
                "status": { "type": "string", "minLength": 1 },
                "achieved_count": { "type": "integer", "minimum": 0 },
                "total_count": { "type": "integer", "minimum": 0 },
                "threshold": { "type": "number", "minimum": 0 }
              }
            },
            "updated_at": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "curriculum": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "curriculum_id",
            "curriculum_title",
            "current_stage_id",
            "current_stage_title",
            "current_stage_description",
            "current_module_id",
            "current_module_title",
            "stage_position",
            "total_stages",
            "status",
            "mastery_status",
            "review_status",
            "target_subskills",
            "recommended_repetition",
            "current_stage_scenarios",
            "completed_stage_ids",
            "rationale",
            "attention_reason",
            "metrics"
          ],
          "properties": {
            "curriculum_id": { "type": "string", "minLength": 1 },
            "curriculum_title": { "type": "string", "minLength": 1 },
            "current_stage_id": { "type": "string", "minLength": 1 },
            "current_stage_title": { "type": "string", "minLength": 1 },
            "current_stage_description": { "type": "string", "minLength": 1 },
            "current_module_id": { "type": "string", "minLength": 1 },
            "current_module_title": { "type": "string", "minLength": 1 },
            "stage_position": { "type": "integer", "minimum": 1 },
            "total_stages": { "type": "integer", "minimum": 1 },
            "status": { "type": "string", "minLength": 1 },
            "mastery_status": {
              "type": "string",
              "enum": ["needs_practice", "improving", "stable", "mastered"]
            },
            "review_status": {
              "type": "string",
              "enum": ["focus_now", "maintain", "soon", "due"]
            },
            "next_review_in_sessions": { "type": ["integer", "null"], "minimum": 0 },
            "target_subskills": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "recommended_repetition": { "type": "integer", "minimum": 1 },
            "current_stage_scenarios": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "scenario_id",
                  "title",
                  "attempt_count",
                  "required",
                  "remaining_repetitions"
                ],
                "properties": {
                  "scenario_id": { "type": "string", "minLength": 1 },
                  "title": { "type": "string", "minLength": 1 },
                  "attempt_count": { "type": "integer", "minimum": 0 },
                  "required": { "type": "boolean" },
                  "remaining_repetitions": { "type": "integer", "minimum": 0 }
                }
              }
            },
            "completed_stage_ids": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "rationale": { "type": "string", "minLength": 1 },
            "next_stage_id": { "type": ["string", "null"] },
            "next_stage_title": { "type": ["string", "null"] },
            "attention_reason": { "type": "string", "minLength": 1 },
            "metrics": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "completed_sessions",
                "required_scenarios_completed",
                "required_scenarios_total",
                "average_stage_score",
                "target_subskill_average"
              ],
              "properties": {
                "completed_sessions": { "type": "integer", "minimum": 0 },
                "required_scenarios_completed": { "type": "integer", "minimum": 0 },
                "required_scenarios_total": { "type": "integer", "minimum": 0 },
                "average_stage_score": { "type": "number", "minimum": 0, "maximum": 100 },
                "target_subskill_average": { "type": "number", "minimum": 0, "maximum": 5 }
              }
            }
          }
        },
        "performance_analytics": {
          "type": "object",
          "additionalProperties": true
        },
        "skill_world": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "map_id",
            "title",
            "active_node_id",
            "summary",
            "nodes",
            "achievements"
          ],
          "properties": {
            "version": { "type": "integer", "minimum": 1 },
            "map_id": { "type": "string", "minLength": 1 },
            "title": { "type": "string", "minLength": 1 },
            "active_node_id": { "type": ["string", "null"] },
            "summary": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "completed_stage_count",
                "total_stage_count",
                "map_progress_percent",
                "earned_achievement_count",
                "mastered_subskill_count",
                "total_subskill_count",
                "current_stage_title"
              ],
              "properties": {
                "completed_stage_count": { "type": "integer", "minimum": 0 },
                "total_stage_count": { "type": "integer", "minimum": 0 },
                "map_progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
                "earned_achievement_count": { "type": "integer", "minimum": 0 },
                "mastered_subskill_count": { "type": "integer", "minimum": 0 },
                "total_subskill_count": { "type": "integer", "minimum": 0 },
                "current_stage_title": { "type": "string", "minLength": 1 }
              }
            },
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "node_id",
                  "kind",
                  "stage_id",
                  "title",
                  "description",
                  "module_id",
                  "position",
                  "status",
                  "progress_percent",
                  "target_subskills",
                  "scenario_ids",
                  "completed_scenario_count",
                  "scenario_count",
                  "required_scenarios_completed",
                  "required_scenarios_total",
                  "mastery_status",
                  "review_status",
                  "rationale",
                  "last_trained_at"
                ],
                "properties": {
                  "node_id": { "type": "string", "minLength": 1 },
                  "kind": { "type": "string", "minLength": 1 },
                  "stage_id": { "type": "string", "minLength": 1 },
                  "title": { "type": "string", "minLength": 1 },
                  "description": { "type": "string", "minLength": 1 },
                  "module_id": { "type": "string", "minLength": 1 },
                  "position": { "type": "integer", "minimum": 1 },
                  "status": { "type": "string", "enum": ["completed", "active", "locked"] },
                  "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
                  "target_subskills": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "scenario_ids": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "completed_scenario_count": { "type": "integer", "minimum": 0 },
                  "scenario_count": { "type": "integer", "minimum": 0 },
                  "required_scenarios_completed": { "type": "integer", "minimum": 0 },
                  "required_scenarios_total": { "type": "integer", "minimum": 0 },
                  "mastery_status": { "type": "string", "minLength": 1 },
                  "review_status": { "type": "string", "minLength": 1 },
                  "rationale": { "type": "string", "minLength": 1 },
                  "last_trained_at": { "type": ["string", "null"] }
                }
              }
            },
            "achievements": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "achievement_id",
                  "kind",
                  "title",
                  "description",
                  "status",
                  "earned_at",
                  "evidence"
                ],
                "properties": {
                  "achievement_id": { "type": "string", "minLength": 1 },
                  "kind": { "type": "string", "minLength": 1 },
                  "title": { "type": "string", "minLength": 1 },
                  "description": { "type": "string", "minLength": 1 },
                  "status": { "type": "string", "minLength": 1 },
                  "earned_at": { "type": ["string", "null"] },
                  "evidence": { "type": "object", "additionalProperties": true }
                }
              }
            }
          }
        }
      }
    },
    "promptContextSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "flags", "contracts"],
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "experiment_id": {
          "type": ["string", "null"]
        },
        "flags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "contracts": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["version"],
            "properties": {
              "version": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "coachContinuity": {
      "type": "object",
