{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillManifest",
  "type": "object",
  "required": [
    "id",
    "version",
    "name",
    "routing",
    "runtime",
    "capabilities",
    "actions",
    "subskills"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "registration": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "required": ["default_for_unscoped_routes"],
      "properties": {
        "default_for_unscoped_routes": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "default_label": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": ["app", "base_path", "health_path", "base_url_env"],
      "properties": {
        "app": {
          "type": "string",
          "minLength": 1
        },
        "base_path": {
          "type": "string",
          "pattern": "^/.*"
        },
        "health_path": {
          "type": "string",
          "pattern": "^/.*"
        },
        "base_url_env": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/capability" }
    },
    "actions": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/action" }
    },
    "subskills": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/subskillId" }
    },
    "marketplace": {
      "type": "object",
      "description": "Optional marketplace display metadata for skill discovery and installation UI.",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "locales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 2 }
        },
        "modality": {
          "type": "string",
          "enum": ["text", "voice", "video", "mixed"]
        },
        "maturity": {
          "type": "string",
          "enum": ["spike", "alpha", "beta", "stable", "deprecated"]
        },
        "compatibility": {
          "type": "object",
          "properties": {
            "min_runtime_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
          },
          "additionalProperties": false
        },
        "privacy": {
          "type": "object",
          "properties": {
            "data_notes": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "capabilityId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "actionId": {
      "type": "string",
      "enum": [
        "list_scenarios",
        "get_evaluation_gates",
        "get_curriculum",
        "get_organization_reports",
        "start_session",
        "get_session",
        "send_turn",
        "finish_session",
        "get_review",
        "get_session_events",
        "get_progress_snapshot"
      ]
    },
    "surface": {
      "type": "string",
      "enum": ["root", "skill"]
    },
    "capability": {
      "type": "object",
      "required": ["id", "name", "description", "actions"],
      "properties": {
        "id": { "$ref": "#/$defs/capabilityId" },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/actionId" }
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["id", "capability", "method", "path", "expose", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/actionId" },
        "capability": { "$ref": "#/$defs/capabilityId" },
        "method": {
          "type": "string",
          "enum": ["GET", "POST"]
        },
        "path": {
          "type": "string",
          "pattern": "^/.*"
        },
        "expose": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/surface" }
        },
        "path_params": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "default": []
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "subskillId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    }
  },
  "additionalProperties": false
}
