{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoachFeedback",
  "type": "object",
  "required": ["version", "focus_subskills", "next_actions"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "focus_subskills": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/subskillId"
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 280
      }
    }
  },
  "$defs": {
    "subskillId": {
      "type": "string",
      "enum": [
        "preparation",
        "opening",
        "profiling",
        "scientific_delivery",
        "need_discovery",
        "objection_handling",
        "closing_followup"
      ]
    }
  },
  "additionalProperties": false
}
