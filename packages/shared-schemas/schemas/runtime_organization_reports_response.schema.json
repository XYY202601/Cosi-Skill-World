{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeOrganizationReportsResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "organization_id",
    "organization_scope",
    "generated_at",
    "team_summary",
    "learners"
  ],
  "properties": {
    "organization_id": { "type": "string", "minLength": 1 },
    "organization_scope": { "type": "string", "enum": ["global", "organization"] },
    "generated_at": { "type": "string", "minLength": 1 },
    "team_summary": { "$ref": "#/$defs/teamSummary" },
    "learners": {
      "type": "array",
      "items": { "$ref": "#/$defs/learnerSummary" }
    }
  },
  "$defs": {
    "weakness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subskill_id", "occurrences", "affected_learners"],
      "properties": {
        "subskill_id": { "type": "string", "minLength": 1 },
        "occurrences": { "type": "integer", "minimum": 0 },
        "affected_learners": { "type": "integer", "minimum": 0 }
      }
    },
    "attentionReason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "detail"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "subskill_id": { "type": ["string", "null"] },
        "severity": { "type": ["string", "null"] }
      }
    },
    "reviewSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "learner_id",
        "scenario_id",
        "scenario_title",
        "status",
        "started_at",
        "updated_at",
        "priority_subskills",
        "review_ready"
      ],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "learner_id": { "type": "string", "minLength": 1 },
        "scenario_id": { "type": "string", "minLength": 1 },
        "scenario_title": { "type": "string", "minLength": 1 },
        "persona_label": { "type": ["string", "null"] },
        "status": { "type": "string", "minLength": 1 },
        "started_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "finish_reason": { "type": ["string", "null"] },
        "overall_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "overall_band": { "type": ["string", "null"] },
        "prompt_profile": { "type": ["string", "null"] },
        "max_compliance_severity": { "type": ["string", "null"] },
        "priority_subskills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "review_ready": { "type": "boolean" }
      }
    },
    "learnerSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "learner_id",
        "total_sessions",
        "finalized_sessions",
        "active_sessions",
        "practice_completion_rate",
        "recurring_weaknesses",
        "active_focus_subskills",
        "needs_attention",
        "needs_attention_reasons",
        "recent_reviews"
      ],
      "properties": {
        "learner_id": { "type": "string", "minLength": 1 },
        "learner_hash": { "type": ["string", "null"] },
        "total_sessions": { "type": "integer", "minimum": 0 },
        "finalized_sessions": { "type": "integer", "minimum": 0 },
        "active_sessions": { "type": "integer", "minimum": 0 },
        "average_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "last_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "practice_completion_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "highest_compliance_severity": { "type": ["string", "null"] },
        "recurring_weaknesses": {
          "type": "array",
          "items": { "$ref": "#/$defs/weakness" }
        },
        "active_focus_subskills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "needs_attention": { "type": "boolean" },
        "needs_attention_reasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/attentionReason" }
        },
        "latest_session_at": { "type": ["string", "null"] },
        "latest_scenario_title": { "type": ["string", "null"] },
        "recent_reviews": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewSummary" }
        }
      }
    },
    "teamSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "learner_count",
        "total_sessions",
        "finalized_sessions",
        "active_sessions",
        "practice_completion_rate",
        "compliance_risk_session_count",
        "high_risk_session_count",
        "at_risk_learner_count",
        "recurring_weaknesses"
      ],
      "properties": {
        "learner_count": { "type": "integer", "minimum": 0 },
        "total_sessions": { "type": "integer", "minimum": 0 },
        "finalized_sessions": { "type": "integer", "minimum": 0 },
        "active_sessions": { "type": "integer", "minimum": 0 },
        "average_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "practice_completion_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "compliance_risk_session_count": { "type": "integer", "minimum": 0 },
        "high_risk_session_count": { "type": "integer", "minimum": 0 },
        "at_risk_learner_count": { "type": "integer", "minimum": 0 },
        "recurring_weaknesses": {
          "type": "array",
          "items": { "$ref": "#/$defs/weakness" }
        },
        "latest_activity_at": { "type": ["string", "null"] }
      }
    }
  }
}
